{
  "description": "DCA gate — reminds (or blocks, in enforce mode) when a watched process-critical path is edited without a fresh decision artifact",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/dca-gate.sh",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/dca-gate.sh",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}
